{
  "expo": {
    "name": "Zamani",
    "slug": "Zamani",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zamani",
    "icon": "./assets/images/zamani.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/zamani.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE7"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}